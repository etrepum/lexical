{
  "name": "@lexical/mdast",
  "description": "Spec-compliant mdast/CommonMark integration for Lexical.",
  "keywords": [
    "lexical",
    "editor",
    "markdown",
    "mdast",
    "commonmark"
  ],
  "license": "MIT",
  "version": "0.45.0",
  "types": "./dist/typescript-too-old.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical-mdast"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types@<5.2": "./dist/typescript-too-old.d.ts",
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalMdast.dev.mjs",
        "production": "./dist/LexicalMdast.prod.mjs",
        "node": "./dist/LexicalMdast.node.mjs",
        "default": "./dist/LexicalMdast.mjs"
      },
      "require": {
        "types@<5.2": "./dist/typescript-too-old.d.ts",
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalMdast.dev.js",
        "production": "./dist/LexicalMdast.prod.js",
        "default": "./dist/LexicalMdast.js"
      }
    },
    "./gfm": {
      "source": "./src/gfm.ts",
      "import": {
        "types@<5.2": "./dist/typescript-too-old.d.ts",
        "types": "./dist/gfm.d.ts",
        "development": "./dist/LexicalMdastGfm.dev.mjs",
        "production": "./dist/LexicalMdastGfm.prod.mjs",
        "node": "./dist/LexicalMdastGfm.node.mjs",
        "default": "./dist/LexicalMdastGfm.mjs"
      },
      "require": {
        "types@<5.2": "./dist/typescript-too-old.d.ts",
        "types": "./dist/gfm.d.ts",
        "development": "./dist/LexicalMdastGfm.dev.js",
        "production": "./dist/LexicalMdastGfm.prod.js",
        "default": "./dist/LexicalMdastGfm.js"
      }
    }
  },
  "dependencies": {
    "@lexical/code": "workspace:*",
    "@lexical/extension": "workspace:*",
    "@lexical/link": "workspace:*",
    "@lexical/list": "workspace:*",
    "@lexical/rich-text": "workspace:*",
    "@types/mdast": "^4.0.4",
    "lexical": "workspace:*",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-gfm": "^3.0.0"
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "typesVersions": {
    "*": {
      "*": [
        "./dist/typescript-too-old.d.ts"
      ]
    }
  },
  "peerDependencies": {
    "typescript": ">=5.2"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
